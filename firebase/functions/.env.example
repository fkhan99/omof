# Gmail SMTP for requestVerificationEmail (Cloud Functions).
# Copy to firebase/functions/.env.local for the emulator only.
# Production uses: firebase functions:config:set (see scripts/configure-verification-smtp.mjs)

OMOF_SMTP_HOST=smtp.gmail.com
OMOF_SMTP_PORT=587
OMOF_SMTP_USER=omofverified@gmail.com
OMOF_SMTP_FROM=OMOF <omofverified@gmail.com>
OMOF_SMTP_PASS=

# Content moderation (Cloud Functions). Use "rules" for keyword classifier; "openai" when configured.
MODERATION_PROVIDER=rules
# OPENAI_API_KEY=

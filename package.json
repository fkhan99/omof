{
  "name": "omof",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "expo start",
    "start:dev": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:ios:dev": "npx eas build --profile development --platform ios",
    "build:android:dev": "npx eas build --profile development --platform android",
    "device:register": "npx eas device:create",
    "env:push:dev": "npx eas env:push --environment development --path .env",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "firebase:deploy:storage": "cd firebase && npx firebase-tools deploy --only storage --project omof-eed24",
    "firebase:deploy:rules": "cd firebase && npx firebase-tools deploy --only firestore:rules,firestore:indexes --project omof-eed24",
    "firebase:deploy:functions": "cd firebase && npx firebase-tools deploy --only functions --project omof-eed24",
    "firebase:deploy:backend": "npm run firebase:build:functions && cd firebase && npx firebase-tools deploy --only functions,firestore:rules --project omof-eed24",
    "firebase:build:functions": "cd firebase/functions && npm run build",
    "firebase:purge-user": "npm run firebase:build:functions && node scripts/purge-user-data.mjs",
    "firebase:deploy:media-rules": "cd firebase && npx firebase-tools deploy --only firestore:rules,storage --project omof-eed24",
    "backup:push": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/git-backup.ps1",
    "backup:setup": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-github-backup.ps1",
    "backup:watch": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/watch-backup.ps1"
  },
  "dependencies": {
    "@expo/ngrok": "^4.1.3",
    "@expo/vector-icons": "^15.1.1",
    "@hookform/resolvers": "^5.4.0",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@tanstack/react-query": "^5.101.0",
    "bad-words": "^4.0.0",
    "date-fns": "^4.4.0",
    "expo": "~56.0.12",
    "expo-constants": "~56.0.18",
    "expo-dev-client": "~56.0.20",
    "expo-device": "^56.0.4",
    "expo-file-system": "^56.0.8",
    "expo-font": "~56.0.6",
    "expo-image": "^56.0.11",
    "expo-image-manipulator": "~56.0.19",
    "expo-image-picker": "~56.0.18",
    "expo-linking": "~56.0.14",
    "expo-notifications": "~56.0.18",
    "expo-router": "~56.2.11",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-video": "~56.1.4",
    "expo-video-thumbnails": "~56.0.3",
    "expo-web-browser": "~56.0.5",
    "firebase": "^12.14.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.79.0",
    "react-native": "0.85.3",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@react-native/jest-preset": "^0.86.0",
    "@testing-library/react-native": "^14.0.0",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jest": "~29.7.0",
    "jest-expo": "^56.0.5",
    "prettier": "^3.8.4",
    "react-test-renderer": "^19.2.3",
    "ts-jest": "^29.4.11",
    "typescript": "~6.0.3"
  }
}

# Copy this file to `.env` in the project root and replace every value with your
# Firebase Web app credentials.
#
# Where to find them:
#   Firebase Console → Project Settings (gear icon) → Your apps → Web app → SDK setup
#
# After editing, restart Expo with a clean cache:
#   npx expo start -c

EXPO_PUBLIC_FIREBASE_API_KEY=AIzaSy...
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
EXPO_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef123456
